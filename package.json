{
  "name": "@sqaoss/flowy",
  "version": "1.1.0",
  "description": "Agentic persistent planning",
  "type": "module",
  "bin": {
    "flowy": "./src/index.ts"
  },
  "files": [
    "src/",
    "server/src/",
    "server/package.json",
    "server/Dockerfile",
    "skills/",
    "!skills/_artifacts",
    "docker-compose.yml",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sqaoss/flowy.git"
  },
  "homepage": "https://github.com/sqaoss/flowy",
  "bugs": {
    "url": "https://github.com/sqaoss/flowy/issues"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "keywords": [
    "cli",
    "ai",
    "project-management",
    "coding-agent",
    "ai-agents",
    "graphql",
    "bun",
    "agentic",
    "planning"
  ],
  "scripts": {
    "cli": "bun src/index.ts",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "commander": "^14.0.3",
    "semantic-release": "25.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "tdd-guard-vitest": "^0.1.6",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,jsonc}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
