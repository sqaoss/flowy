{
  "name": "@sqaoss/flowy",
  "version": "0.1.1",
  "description": "CLI for Flowy — project management for AI coding agents. NOTE: Registration is temporarily closed while in rapid development.",
  "type": "module",
  "bin": {
    "flowy": "./src/index.ts"
  },
  "files": [
    "src/",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/sqaoss/flowy.git"
  },
  "homepage": "https://github.com/sqaoss/flowy",
  "bugs": {
    "url": "https://github.com/sqaoss/flowy/issues"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "keywords": [
    "cli",
    "ai",
    "project-management",
    "coding-agent",
    "ai-agents",
    "graphql",
    "bun"
  ],
  "scripts": {
    "cli": "bun src/index.ts",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,jsonc}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
